# 构建输出
build/
.hvigor/
oh_modules/
*.build
*.hvigor

# IDE 配置
.idea/
.vscode/
*.iml

# 预览文件
.preview/

# 本地配置文件
local.properties

# 生成的签名文件
*.p12
*.jks

# 模块内的构建产物
common/*/build/
common/*/oh_modules/
features/*/build/
features/*/oh_modules/
products/*/build/
products/*/oh_modules/

# 模块内的 BuildProfile.ets
common/*/BuildProfile.ets
features/*/BuildProfile.ets
products/*/BuildProfile.ets

# 锁文件（可选，如果希望保持依赖一致可以保留，但通常不提交）
**/oh-package-lock.json5